{
  "name": "@studio/desktop",
  "version": "1.0.0",
  "type": "module",
  "description": "AI Documentary Studio Desktop Application",
  "author": "DevBySharif",
  "private": true,
  "main": "dist/apps/desktop/src/main.js",
  "build": {
    "appId": "com.aidocumentarystudio.desktop",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*"
    ]
  },
  "scripts": {
    "dev": "tsc --noEmit false --outDir dist && vite",
    "start": "electron .",
    "build": "tsc --noEmit false --outDir dist && vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@studio/shared": "workspace:*",
    "reflect-metadata": "^0.2.0",
    "tsyringe": "^4.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.2",
    "@tanstack/react-query": "^5.28.9",
    "lucide-react": "^0.364.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.4.3"
  }
}
